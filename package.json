{
  "name": "olive-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Olive V0 — AI voice agent for independent restaurants. Paradise Biryani pilot demo.",
  "scripts": {
    "demo": "make demo",
    "backend": "pnpm --filter @olive/backend dev",
    "dashboard": "pnpm --filter @olive/dashboard dev",
    "seed": "pnpm --filter @olive/backend seed",
    "seed:menu": "pnpm --filter @olive/seed parse",
    "noise:test": "pnpm --filter @olive/noise-tests run",
    "tunnel": "ngrok http --domain=$NGROK_DOMAIN 8787"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  }
}
