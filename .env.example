# =========================================================================
# Olive V0 — Environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# =========================================================================

# --- Server ---
PORT=8787
NODE_ENV=development
LOG_LEVEL=info                                # debug | info | warn | error

# --- Auth ---
# Generate with: openssl rand -hex 32
# This token guards all write endpoints (orders/items/stock).
# Set the same value in your ElevenLabs agent tool headers.
OLIVE_AGENT_TOKEN=

# --- Database (Supabase Postgres) ---
# Supabase dashboard → Project Settings → Database → Connection string → Session pooler
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DO NOT URL-encode the password unless it contains special chars Postgres can't handle in URIs.
SUPABASE_DB_URL=

# --- Restaurant identity (used in system prompt) ---
RESTAURANT_NAME=Paradise Biryani
RESTAURANT_TIMEZONE=America/Los_Angeles
RESTAURANT_PICKUP_ONLY=true

# --- Cost & safety guardrails ---
MAX_CALL_SECONDS=480                          # 8-minute hard cap
MAX_TOKENS_PER_TURN=500
MAX_TOKENS_PER_CALL=20000
RATE_LIMIT_CALLS_PER_HOUR=5                   # per phone number
DAILY_CALL_BUDGET_USD=25                      # kill switch

# --- ElevenLabs ---
# Get from https://elevenlabs.io/app/conversational-ai
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=                          # Indian English voice from Voice Library
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# --- LLM (Anthropic primary, OpenAI fallback) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                               # fallback if Claude webhook adds too much latency
OPENAI_MODEL=gpt-4o

# --- Deepgram (used only on LiveKit fallback path) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# --- Twilio (Phase 3 / when number is provisioned) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Tunneling ---
# Optional: pin to a stable ngrok subdomain (paid plan) so ElevenLabs webhook URL doesn't change.
# If unset, `make tunnel` will give you a random URL each run.
NGROK_DOMAIN=
# Public base URL where ElevenLabs can reach your backend.
# Example: https://olive-demo.ngrok.app
PUBLIC_BASE_URL=
